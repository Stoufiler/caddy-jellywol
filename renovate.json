{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major",
      "matchPackageNames": [
        "*"
      ]
    }
  ],
  "gomod": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  }
}
